{
  "name": "opencluely",
  "version": "1.0.0",
  "description": "AI Problem Solving Assistant",
  "main": "main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron . --no-sandbox --disable-gpu",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --mac --win --linux",
    "dist": "npm run build",
    "pack": "electron-builder --dir",
    "clean": "rm -rf dist/",
    "rebuild": "npm run clean && npm run build",
    "release": "npm run clean && npm run build:all",
    "postinstall": "electron-builder install-app-deps",
    "predev": "node scripts/patch-electron.js",
    "patch-electron": "node scripts/patch-electron.js"
  },
  "author": {
    "name": "empty06"
  },
  "repository": {
    "type": "git",
    "url": "<your-repository-url>"
  },
  "license": "ISC",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^16.3.1",
    "markdown": "^0.5.0",
    "marked": "^15.0.12",
    "prismjs": "^1.30.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-reloader": "^1.2.3",
    "playwright": "^1.61.1"
  },
  "build": {
    "appId": "com.opencluely.app",
    "productName": "EmptyButHD",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!*.md",
      "!.git/**/*",
      "!.env*"
    ],
    "extraFiles": [
      {
        "from": "public/assets/prompts",
        "to": "prompts"
      }
    ],
    "asarUnpack": [
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/assets/icons/app-icon.icns",
      "darkModeSupport": true,
      "extendInfo": {
        "LSUIElement": true
      },
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "config/build/entitlements.mac.plist",
      "entitlementsInherit": "config/build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "public/assets/icons/app-icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/assets/icons/app-icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "title": "EmptyButHD Interview Assistant",
      "backgroundColor": "#000000",
      "window": {
        "width": 600,
        "height": 400
      }
    }
  }
}
